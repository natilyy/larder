# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Database ---
# When running the API inside docker-compose, host is the service name "postgres".
# When running the API locally (npm run start:dev) against the compose DB, use localhost.
DATABASE_URL="postgresql://larder:larder@localhost:5432/larder?schema=public"

# Used by the postgres service in docker-compose.yml
POSTGRES_USER=larder
POSTGRES_PASSWORD=larder
POSTGRES_DB=larder

# --- API ---
PORT=3000
NODE_ENV=development

# --- Open Food Facts ---
# Public, no API key required. Override only if self-hosting a mirror.
OFF_BASE_URL="https://world.openfoodfacts.org"

# --- AI (Phase 3, optional) ---
# Get a key at https://console.anthropic.com — leave blank until you build meal planning.
ANTHROPIC_API_KEY=
